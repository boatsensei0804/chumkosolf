# คัดลอกเป็น .env แล้วแก้ค่า (ห้าม commit .env จริง)

# --- PostgreSQL ---
POSTGRES_USER=chumko
POSTGRES_PASSWORD=chumko_dev_pwd
POSTGRES_DB=chumko

# --- Backend ---
# JWT secret สำหรับ sign access/refresh token (สุ่มยาว ๆ ใน prod)
JWT_SECRET=dev_jwt_secret_change_me

# คีย์เข้ารหัสข้อมูลอ่อนไหว (เลขบัตรประชาชน) — AES-256, hex 32 ไบต์ (64 ตัวอักษร)
# สร้างใหม่ด้วย: openssl rand -hex 32
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

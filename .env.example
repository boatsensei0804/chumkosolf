# คัดลอกเป็น .env แล้วแก้ค่า (ห้าม commit .env จริง)

# --- PostgreSQL ---
POSTGRES_USER=chumkosoft
POSTGRES_PASSWORD=chumkosoft_dev_pwd
POSTGRES_DB=chumkosoft

# --- Backend ---
# JWT secret สำหรับ sign access/refresh token (สุ่มยาว ๆ ใน prod)
JWT_SECRET=dev_jwt_secret_change_me

# คีย์เข้ารหัสข้อมูลอ่อนไหว (เลขบัตรประชาชน) — AES-256, hex 32 ไบต์ (64 ตัวอักษร)
# สร้างใหม่ด้วย: openssl rand -hex 32
ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# --- Object storage (MinIO / S3) สำหรับไฟล์แนบส่วนบุคคล (ผลงานครู) ---
# ไฟล์เข้าถึงผ่าน signed URL ที่หมดอายุ ไม่ใช่ public bucket
MINIO_ROOT_USER=chumkosoft
MINIO_ROOT_PASSWORD=chumkosoft_dev_pwd
# public endpoint ที่เบราว์เซอร์ใช้โหลดไฟล์ตาม signed URL (host ที่ resolve ได้จากภายนอก)
STORAGE_PUBLIC_ENDPOINT=localhost:9000
STORAGE_BUCKET=chumkosoft-files

# --- Face recognition (สแกนหน้าเข้าเรียน) ---
# base URL ของ face-svc (ตั้งใน docker-compose แล้ว); ว่าง = ปิดฟีเจอร์
# FACE_SERVICE_URL=http://face-svc:8000
# ตรวจ liveness (ต้องขยับหน้า) ตอนสแกน: on = เปิด, ปิดไว้ = สแกนเฟรมเดียวทันที
FACE_LIVENESS=off

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
